{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "betterstack-utils",
  "title": "BetterStack Utils",
  "description": "View your BetterStack Primary on-call schedule",
  "icon": "extension-icon.png",
  "author": "doktor500",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "on-call-schedule",
      "title": "On Call Schedule",
      "description": "Shows a 3-month on-call grid for the Primary schedule",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiToken",
      "title": "API Token",
      "description": "Your BetterStack API token",
      "type": "password",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.17"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "~25.8.0",
    "@types/react": "~19.2.14",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  }
}
